{
	"info": {
		"_postman_id": "85483c7d-daf9-4a04-90f6-6b813dca49a6",
		"name": "Reimbursement Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Signup (Create Company)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"companyName\": \"Acme Corp\",\r\n    \"country\": \"USA\",\r\n    \"adminName\": \"John Admin\",\r\n    \"adminEmail\": \"admin@acme.com\",\r\n    \"adminPassword\": \"password123\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "http://localhost:5000/api/auth/signup"
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"email\": \"admin@acme.com\",\r\n    \"password\": \"password123\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "http://localhost:5000/api/auth/login"
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"name\": \"Jane Doe\",\r\n    \"email\": \"jane@acme.com\",\r\n    \"role\": \"Employee\",\r\n    \"manager_id\": 1\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "http://localhost:5000/api/users/create"
					}
				}
			]
		},
		{
			"name": "Expenses",
			"item": [
				{
					"name": "Submit Expense",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "amount", "value": "100.50", "type": "text" },
								{ "key": "currency", "value": "EUR", "type": "text" },
								{ "key": "category", "value": "Travel", "type": "text" },
								{ "key": "description", "value": "Flight to Paris", "type": "text" },
								{ "key": "date", "value": "2024-05-10", "type": "text" },
								{ "key": "status", "value": "pending", "type": "text" },
								{ "key": "receipt", "type": "file", "src": "/path/to/receipt.jpg" }
							]
						},
						"url": "http://localhost:5000/api/expenses"
					}
				}
			]
		}
	]
}
